{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "tinylemon.vercel.app"
        }
      ],
      "destination": "https://tinylemon.xyz/:path*",
      "permanent": true
    }
  ],
  "buildCommand": "npx prisma generate && npx prisma migrate deploy && npm run build"
}
