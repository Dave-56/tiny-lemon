{
  "name": "tiny-lemon",
  "private": true,
  "scripts": {
    "build": "react-router build",
    "dev": "shopify app dev --tunnel-url https://unacoustical-nonembryonic-jaimie.ngrok-free.dev:3000",
    "tunnel": "ngrok http --domain=unacoustical-nonembryonic-jaimie.ngrok-free.dev 3000",
    "config:link": "shopify app config link",
    "generate": "shopify app generate",
    "deploy": "shopify app deploy",
    "config:use": "shopify app config use",
    "env": "shopify app env",
    "start": "react-router-serve ./build/server/index.js",
    "docker-start": "npm run setup && npm run start",
    "setup": "prisma generate && prisma migrate deploy",
    "lint": "eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "shopify": "shopify",
    "prisma": "prisma",
    "graphql-codegen": "graphql-codegen",
    "vite": "vite",
    "typecheck": "react-router typegen && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed:presets": "npx tsx scripts/generate-preset-previews.ts",
    "seed:three-quarter": "npx tsx scripts/generate-three-quarter-preview.ts"
  },
  "type": "module",
  "engines": {
    "node": ">=20.19 <22 || >=22.12"
  },
  "dependencies": {
    "@google/genai": "^1.44.0",
    "@prisma/client": "^6.16.3",
    "@react-router/dev": "^7.12.0",
    "@react-router/fs-routes": "^7.12.0",
    "@react-router/node": "^7.12.0",
    "@react-router/serve": "^7.12.0",
    "@shopify/app-bridge-react": "^4.2.4",
    "@shopify/shopify-app-react-router": "^1.1.0",
    "@shopify/shopify-app-session-storage-prisma": "^8.0.0",
    "@trigger.dev/sdk": "^4.4.2",
    "@vercel/blob": "^2.3.1",
    "@vercel/react-router": "^1.2.5",
    "fflate": "^0.8.2",
    "isbot": "^5.1.31",
    "lucide-react": "^0.577.0",
    "marked": "^17.0.4",
    "motion": "^12.35.0",
    "prisma": "^6.16.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.12.0",
    "sharp": "^0.34.5",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "devDependencies": {
    "@shopify/api-codegen-preset": "^1.2.0",
    "@shopify/polaris-types": "^1.0.1",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^14.3.0",
    "@types/eslint": "^9.6.1",
    "@types/node": "^22.18.8",
    "@types/react": "^18.3.25",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "graphql-config": "^5.1.1",
    "jsdom": "^25.0.0",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vite": "^6.3.6",
    "vitest": "^2.1.0"
  },
  "workspaces": [
    "extensions/*"
  ],
  "trustedDependencies": [
    "@shopify/plugin-cloudflare"
  ],
  "overrides": {
    "p-map": "^4.0.0"
  },
  "author": "preciousemakenemi",
  "optionalDependencies": {
    "@img/sharp-linux-x64": "^0.34.0"
  }
