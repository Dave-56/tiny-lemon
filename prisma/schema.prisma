generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Shop {
  id                      String         @id // myshopify_domain e.g. "my-store.myshopify.com"
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  plan                    String         @default("free") // free | Starter | Growth | Scale
  betaAccess              Boolean        @default(false)
  betaStatus              String?
  betaCap                 Int?
  betaGrantedAt           DateTime?
  betaGrantedBy           String?
  betaGrantedReason       String?
  betaActivatedAt         DateTime?
  betaWelcomeCompleted    Boolean        @default(false)
  betaIntakeCompleted     Boolean        @default(false)
  betaOnboardingCompleted Boolean        @default(false)
  contactEmail            String?
  storeUrl                String?
  catalogType             String?
  skuVolume               String?
  photoWorkflow           String?
  biggestPain             String?
  intendedUseCase         String?
  launchStage             String?
  shootGoal               String?
  heroProductFocus        String?
  stylingSupport          String?
  graphicSensitivity      String?
  outputChannels          String[]       @default([])
  intakeNotes             String?
  betaFeedback            BetaFeedback[]

  outfits       Outfit[]
  models        Model[]
  brandStyle    BrandStyle?
  creditBalance CreditBalance?
  transactions  CreditTransaction[]
  requestIdempotencies RequestIdempotency[]
  outfitGenerationRequests OutfitGenerationRequest[]
  singleImageRegenerationAllowances SingleImageRegenerationAllowance[]
}

model BrandStyle {
  shopId              String   @id
  angleIds            String[]
  brandStyleId        String   @default("minimal") @map("stylingDirectionId")
  brandEnergy         String?  // minimal | accessible | editorial | premium | street | athletic
  primaryCategory     String?  // womenswear | menswear | unisex | activewear | streetwear | formalwear | other
  pricePoint          String?  // value | mid-market | premium | luxury
  onboardingCompleted Boolean  @default(false)
  updatedAt           DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model Model {
  id           String   @id @default(cuid())
  shopId       String
  name         String
  gender       String
  ethnicity    String
  skinTone     String
  bodyBuild    String
  height       String
  hairStyle    String
  hairColor    String
  ageRange     String
  estimatedAge String?
  imageUrl     String
  isPreset     Boolean  @default(false)
  styleId      String
  angleId      String
  createdAt    DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model Outfit {
  id                   String    @id @default(cuid())
  shopId               String
  name                 String
  frontFlatLayUrl      String
  backFlatLayUrl       String?
  cleanFlatLayUrl      String?   // cleaned studio flat lay (Gemini post-process) — input to all generation
  cleanBackFlatLayUrl  String?   // cleaned back flat lay
  garmentSpec          Json?
  modelId              String    // preset model ID or batchId of user-generated model
  brandStyleId         String    @default("minimal") @map("stylingDirectionId") // preset id from BRAND_STYLE_PRESETS (body language/backdrop)
  generationDirection  String?   // optional merchant shoot-level styling/background/mood direction
  status               String    @default("pending") // pending | processing | completed | failed
  jobId                String?   // Trigger.dev runId
  errorMessage         String?   // failure reason, set on task failure
  shopifyProductId     String?   // GID: "gid://shopify/Product/123"
  shopifyProductUrl    String?   // Shopify admin URL for deep-linking
  shopifyProductCreatedByApp Boolean @default(false) // true when this app created the product (safe to overwrite media); false when merchant picked an existing product
  shopifySyncedAt      DateTime? // timestamp of last successful sync
  shopifySyncStartedAt DateTime? // timestamp of current/most recent sync start
  shopifySyncStatus    String?   // syncing | synced | stale | failed
  videoStatus          String?   // null | pending | processing | completed | failed
  videoJobId           String?   // Trigger.dev runId for generate-video task
  videoUrl             String?   // Vercel Blob MP4 URL
  videoErrorMessage    String?   // failure reason from video generation
  videoGeneratedAt     DateTime? // timestamp of last successful video generation
  shopifyVideoFileId   String?   // GID: "gid://shopify/Video/123" from Shopify Files
  shopifyVideoMediaId  String?   // Product media GID for the associated Shopify-hosted video
  deletedAt            DateTime?
  createdAt            DateTime  @default(now())

  shop   Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  images GeneratedImage[]
  generationRequests OutfitGenerationRequest[]
  singleImageRegenerationAllowances SingleImageRegenerationAllowance[]

  @@index([shopId, deletedAt, createdAt])
}

model OutfitGenerationRequest {
  id                String    @id @default(cuid())
  shopId            String
  outfitId          String
  operation         String    // generate | regenerate
  merchantDirection String?
  frontDescription  String?
  backDescription   String?
  targetPoses       String[]  @default([])
  resolvedPoses     String[]  @default([])
  modelId           String
  brandStyleId      String
  brandEnergy       String?
  pricePoint        String?
  primaryCategory   String?
  requestKey        String
  runToken          String
  jobId             String?
  status            String    @default("pending") // pending | enqueued | completed | failed
  failureReason     String?
  createdAt         DateTime  @default(now())
  enqueuedAt        DateTime?
  completedAt       DateTime?
  failedAt          DateTime?
  updatedAt         DateTime  @updatedAt

  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  outfit Outfit @relation(fields: [outfitId], references: [id], onDelete: Cascade)

  @@unique([shopId, operation, requestKey, runToken])
  @@index([shopId, status, createdAt])
  @@index([outfitId, createdAt])
  @@index([jobId])
}

model SingleImageRegenerationAllowance {
  id          String    @id @default(cuid())
  shopId      String
  outfitId    String
  pose        String
  status      String    @default("pending") // pending | completed | failed
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  outfit Outfit @relation(fields: [outfitId], references: [id], onDelete: Cascade)

  @@unique([outfitId, pose])
  @@index([shopId, status])
}

model GeneratedImage {
  id            String    @id @default(cuid())
  shopId        String
  outfitId      String
  imageUrl      String    // Vercel Blob URL
  assetManifest Json?
  pose          String    // front | three-quarter | back | torso-crop
  styleId       String?   // styling direction preset
  upscaleStatus String?   // null | pending | processing | completed | failed
  upscaleJobId  String?   // Trigger.dev runId for the upscale task
  upscaledAt    DateTime? // timestamp for cache-busting and audit
  createdAt     DateTime  @default(now())

  outfit Outfit @relation(fields: [outfitId], references: [id], onDelete: Cascade)

  @@unique([outfitId, pose])
}

model CreditBalance {
  shopId    String   @id
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model CreditTransaction {
  id          String   @id @default(cuid())
  shopId      String
  amount      Int      // positive = purchase, negative = usage
  type        String   // purchase | usage | refund
  description String?
  createdAt   DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model RequestIdempotency {
  id         String   @id @default(cuid())
  shopId     String
  operation  String
  requestKey String
  status     String
  runToken   String
  outfitId   String?
  jobId      String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, operation, requestKey])
  @@index([shopId, status, expiresAt])
}

model RateLimitEvent {
  id            String   @id @default(cuid())
  namespace     String
  subjectDigest String
  algorithm     String
  windowStart   DateTime?
  createdAt     DateTime @default(now())
  expiresAt     DateTime

  @@index([namespace, subjectDigest, createdAt])
  @@index([namespace, subjectDigest, windowStart])
  @@index([expiresAt])
}

model BetaFeedback {
  id        String   @id @default(cuid())
  shopId     String
  outfitId   String?
  rating     String?
  category   String?
  message    String?
  createdAt  DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
}
