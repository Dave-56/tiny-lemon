generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Shop {
  id        String   @id // myshopify_domain e.g. "my-store.myshopify.com"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  plan      String   @default("free") // free | Starter | Growth | Scale

  outfits       Outfit[]
  models        Model[]
  brandStyle    BrandStyle?
  creditBalance CreditBalance?
  transactions  CreditTransaction[]
}

model BrandStyle {
  shopId             String   @id
  styleIds           String[]
  angleIds           String[]
  stylingDirectionId String   @default("minimal")
  updatedAt          DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model Model {
  id           String   @id @default(cuid())
  shopId       String
  name         String
  gender       String
  ethnicity    String
  skinTone     String
  bodyBuild    String
  height       String
  hairStyle    String
  hairColor    String
  ageRange     String
  estimatedAge String?
  imageUrl     String
  isPreset     Boolean  @default(false)
  styleId      String
  angleId      String
  createdAt    DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model Outfit {
  id                   String   @id @default(cuid())
  shopId               String
  name                 String
  frontFlatLayUrl      String
  backFlatLayUrl       String?
  cleanFlatLayUrl      String?  // cleaned studio flat lay (Gemini post-process) — input to all generation
  cleanBackFlatLayUrl  String?  // cleaned back flat lay
  garmentSpec          Json?
  modelId              String   // preset model ID or batchId of user-generated model
  stylingDirectionId   String   @default("minimal") // preset id from STYLING_DIRECTION_PRESETS (pose/energy)
  status               String   @default("pending") // pending | processing | completed | failed
  jobId                String?  // Trigger.dev runId
  errorMessage         String?  // failure reason, set on task failure
  createdAt            DateTime @default(now())

  shop   Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  images GeneratedImage[]
}

model GeneratedImage {
  id        String   @id @default(cuid())
  shopId    String
  outfitId  String
  imageUrl  String   // Vercel Blob URL
  pose      String   // front | three-quarter | back | torso-crop
  styleId   String?  // styling direction preset
  createdAt DateTime @default(now())

  outfit Outfit @relation(fields: [outfitId], references: [id], onDelete: Cascade)
}

model CreditBalance {
  shopId    String   @id
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model CreditTransaction {
  id          String   @id @default(cuid())
  shopId      String
  amount      Int      // positive = purchase, negative = usage
  type        String   // purchase | usage | refund
  description String?
  createdAt   DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
}
